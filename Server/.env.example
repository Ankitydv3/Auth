PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/eventora?retryWrites=true&w=majority

# Email (production on Render: use Resend — Gmail SMTP is blocked on cloud hosts)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional: verified sender in Resend (e.g. Eventora <noreply@yourdomain.com>)
EMAIL_FROM=Eventora <onboarding@resend.dev>

# Local dev fallback (Gmail app password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
# JWT
JWT_SECRET=your_jwt_secret_key