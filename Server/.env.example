PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/eventora?retryWrites=true&w=majority

# Email — set BOTH for best results (Gmail sends OTPs; Resend used when domain verified)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Use your verified domain sender in production (not onboarding@resend.dev)
EMAIL_FROM=Eventora <noreply@yourdomain.com>

# Gmail app password (required for OTP to any user while Resend domain is unverified)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
# JWT
JWT_SECRET=your_jwt_secret_key