PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/eventora?retryWrites=true&w=majority

# Email on Render (pick ONE approach)

# Option A — Brevo (recommended on Render, no custom domain needed)
# 1. Sign up at https://www.brevo.com
# 2. SMTP & API → API keys → create key
# 3. Senders & IP → add and verify your Gmail
BREVO_API_KEY=xkeysib-xxxxxxxx
EMAIL_USER=your_verified_gmail@gmail.com

# Option B — Resend (requires verified domain for OTP to any user)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Eventora <noreply@yourdomain.com>

# Local dev only (Gmail app password) — SMTP blocked on Render
EMAIL_PASS=your_gmail_app_password

# JWT
JWT_SECRET=your_jwt_secret_key
